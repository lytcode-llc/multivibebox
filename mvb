#!/bin/bash
# mvb — Multivibebox launcher
# Containerized multi-agent vibe coding environment

set -e

MVB_HOME="${MVB_HOME:-$HOME/.mvb}"
MVB_REPO="${MVB_REPO:-$(cat "$MVB_HOME/.repo-path" 2>/dev/null || dirname "$(readlink -f "$0")")}"
MVB_PROJECTS_DIR="$MVB_REPO/config/projects"
MVB_NOTIFY_DIR="$MVB_REPO/notify"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

usage() {
    cat <<'EOF'
Usage: mvb <command> [options]

Commands:
  start [session] [pane-specs...]   Start or resume a session
    --path DIR                      Bind-mount a local folder (single-project mode)
    --shared                        All agents share one directory (no worktrees)
    --agents AGENTS                 Comma-separated agent list (single-project mode)
  stop                              Stop container and host watcher
  list                              List all projects
  attach [pane-name]                Attach to tmux session or a specific pane
  merge                             Interactive merge of agent worktree branches
  open [agent] [file]               Open agent worktree in VS Code
  config                            Edit .env in $EDITOR
  destroy <project>                 Remove a project and its volume
  help                              Show this help

Pane specs (multi-project mode):
  Each pane spec is agent:path — an agent name and a local folder path.
  Multiple panes can share the same path.

Examples:
  # Single project (all panes share one workspace)
  mvb start myproject --path ~/Projects/myproject
  mvb start myproject --path ~/Projects/myproject --agents claude,aider

  # Multi-project (each pane gets its own workspace)
  mvb start coding \
    claude:~/Projects/frontend \
    claude:~/Projects/frontend \
    claude:~/Projects/backend \
    claude:~/Projects/api

  mvb attach claude-frontend-0
  mvb merge
EOF
}

# Load .env if it exists
load_env() {
    local env_file="$MVB_REPO/config/.env"
    if [ -f "$env_file" ]; then
        set -a
        source "$env_file"
        set +a
    fi
}

# Get project metadata file path
project_file() {
    echo "$MVB_PROJECTS_DIR/${1}.json"
}

# Save project metadata
save_project() {
    local name="$1" path="$2" shared="$3" agents="$4"
    mkdir -p "$MVB_PROJECTS_DIR"
    cat > "$(project_file "$name")" <<PROJ
{
  "name": "$name",
  "path": "$path",
  "shared": $shared,
  "agents": "$agents",
  "last_used": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
PROJ
}

# Load project metadata
load_project() {
    local pfile
    pfile=$(project_file "$1")
    if [ -f "$pfile" ]; then
        cat "$pfile"
    fi
}

# Start host watcher in background
start_host_watcher() {
    mkdir -p "$MVB_NOTIFY_DIR"
    # Kill any existing watcher
    stop_host_watcher 2>/dev/null || true

    "$MVB_REPO/scripts/host-watcher.sh" "$MVB_REPO" &
    local watcher_pid=$!
    echo "$watcher_pid" > "$MVB_REPO/.mvb.pid"
    echo -e "${GREEN}Host watcher started (PID: $watcher_pid)${NC}"
}

# Stop host watcher
stop_host_watcher() {
    if [ -f "$MVB_REPO/.mvb.pid" ]; then
        local pid
        pid=$(cat "$MVB_REPO/.mvb.pid")
        kill "$pid" 2>/dev/null || true
        rm -f "$MVB_REPO/.mvb.pid"
    fi
    # Also kill any orphaned watchers
    pkill -f "host-watcher.sh" 2>/dev/null || true
}

# Get the container name for a project
container_name() {
    echo "mvb-${1:-default}"
}

# Check if container is running
is_running() {
    docker ps --format '{{.Names}}' | grep -q "^$(container_name "$1")$"
}

# ---- Commands ----

cmd_start() {
    local session="" workspace_path="" shared="false" agents=""
    local -a pane_specs=()

    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            --path)
                workspace_path="$(cd "$2" && pwd)"
                shift 2
                ;;
            --shared)
                shared="true"
                shift
                ;;
            --agents)
                agents="$2"
                shift 2
                ;;
            -*)
                echo -e "${RED}Unknown option: $1${NC}" >&2
                exit 1
                ;;
            *)
                # Check if this is a pane spec (contains ':')
                if [[ "$1" == *":"* ]]; then
                    pane_specs+=("$1")
                elif [ -z "$session" ]; then
                    session="$1"
                else
                    # Treat as pane spec without colon — assume claude:path
                    pane_specs+=("claude:$1")
                fi
                shift
                ;;
        esac
    done

    # Detect mode: multi-project (pane specs) vs single-project (--path/--agents)
    if [ ${#pane_specs[@]} -gt 0 ]; then
        cmd_start_multi "$session" "$shared" "${pane_specs[@]}"
    else
        cmd_start_single "$session" "$workspace_path" "$shared" "$agents"
    fi
}

# Single-project mode: all panes share one workspace
cmd_start_single() {
    local project="$1" workspace_path="$2" shared="$3" agents="$4"

    # Default project name
    if [ -z "$project" ]; then
        if [ -n "$workspace_path" ]; then
            project=$(basename "$workspace_path")
        else
            project="default"
        fi
    fi

    load_env

    # Try to load existing project settings
    local existing
    existing=$(load_project "$project")
    if [ -n "$existing" ]; then
        echo -e "${BLUE}Resuming project: $project${NC}"
        if [ -z "$workspace_path" ]; then
            workspace_path=$(echo "$existing" | jq -r '.path // empty')
        fi
        if [ "$shared" = "false" ] && [ "$(echo "$existing" | jq -r '.shared')" = "true" ]; then
            shared="true"
        fi
        if [ -z "$agents" ]; then
            agents=$(echo "$existing" | jq -r '.agents // empty')
        fi
    else
        echo -e "${GREEN}Creating new project: $project${NC}"
    fi

    agents="${agents:-${MVB_AGENTS:-claude}}"

    # Check if already running
    if is_running "$project"; then
        echo -e "${YELLOW}Project $project is already running. Attaching...${NC}"
        cmd_attach
        return
    fi

    # Set up workspace volume spec for docker compose
    local volume_spec
    if [ -n "$workspace_path" ]; then
        volume_spec="$workspace_path"
        echo -e "Workspace: ${GREEN}$workspace_path${NC} (bind mount)"
    else
        volume_spec="mvb-${project}"
        docker volume create "mvb-${project}" >/dev/null 2>&1 || true
        echo -e "Workspace: ${GREEN}mvb-${project}${NC} (Docker volume)"
    fi

    echo -e "Agents: ${GREEN}$agents${NC}"
    echo -e "Mode: ${GREEN}$([ "$shared" = "true" ] && echo "shared" || echo "worktree")${NC}"

    save_project "$project" "$workspace_path" "$shared" "$agents"

    start_host_watcher

    local claude_oauth_token
    claude_oauth_token=$(extract_oauth_token)

    cd "$MVB_REPO"
    MVB_PROJECT="$project" \
    MVB_AGENTS="$agents" \
    MVB_SHARED="$shared" \
    MVB_WORKSPACE_VOLUME="$volume_spec" \
    CLAUDE_CODE_OAUTH_TOKEN="$claude_oauth_token" \
    docker compose run --rm --service-ports mvb
}

# Multi-project mode: each pane spec gets its own workspace
cmd_start_multi() {
    local session="$1" shared="$2"
    shift 2
    local -a pane_specs=("$@")

    load_env

    # Auto-generate session name from unique project names if not provided
    if [ -z "$session" ]; then
        local names=""
        for spec in "${pane_specs[@]}"; do
            local p="${spec#*:}"
            p="${p/#\~/$HOME}"
            local n
            n=$(basename "$p")
            # Append if not already in the list
            case ",$names," in
                *",$n,"*) ;;
                *) names="${names:+$names+}$n" ;;
            esac
        done
        session="$names"
    fi

    local pane_count=${#pane_specs[@]}
    local max_panes="${MVB_MAX_PANES:-6}"

    if [ "$pane_count" -gt "$max_panes" ]; then
        echo -e "${YELLOW}WARNING: $pane_count panes requested, max is $max_panes.${NC}"
        echo "Using first $max_panes panes only."
        pane_specs=("${pane_specs[@]:0:$max_panes}")
        pane_count=$max_panes
    fi

    # Check if already running
    if is_running "$session"; then
        echo -e "${YELLOW}Session $session is already running. Attaching...${NC}"
        cmd_attach
        return
    fi

    echo -e "${BLUE}Starting multi-project session: $session${NC}"
    echo -e "Panes: ${GREEN}$pane_count${NC}"

    # Build volume mounts and pane config
    # Track unique paths to avoid duplicate mounts (parallel arrays instead of associative)
    local volume_args=""
    local known_host_paths=""
    local known_container_paths=""
    local mvb_panes=""
    local mount_index=0

    for i in $(seq 0 $((pane_count - 1))); do
        local spec="${pane_specs[$i]}"
        local agent="${spec%%:*}"
        local host_path="${spec#*:}"

        # Expand ~ and resolve to absolute path
        host_path="${host_path/#\~/$HOME}"
        host_path="$(cd "$host_path" 2>/dev/null && pwd)" || {
            echo -e "${RED}Path not found: ${spec#*:}${NC}"
            exit 1
        }

        local project_name
        project_name=$(basename "$host_path")

        # Assign container mount point (reuse if same host path)
        local container_path=""

        # Check if we've already seen this host path
        local found=false
        local idx=0
        while IFS= read -r known; do
            [ -z "$known" ] && continue
            if [ "$known" = "$host_path" ]; then
                # Get the matching container path
                container_path=$(echo "$known_container_paths" | sed -n "$((idx + 1))p")
                found=true
                break
            fi
            idx=$((idx + 1))
        done <<< "$known_host_paths"

        if [ "$found" = "false" ]; then
            container_path="/workspaces/${project_name}"
            # Handle duplicate project names with different paths
            if echo "$known_container_paths" | grep -q "^${container_path}$" 2>/dev/null; then
                container_path="/workspaces/${project_name}-${mount_index}"
            fi
            known_host_paths="${known_host_paths}${host_path}
"
            known_container_paths="${known_container_paths}${container_path}
"
            volume_args="${volume_args} -v ${host_path}:${container_path}"
            mount_index=$((mount_index + 1))
        fi

        # Build pane name: agent-project-index (for unique tmux pane titles)
        local pane_name="${agent}-${project_name}-${i}"

        # Append to MVB_PANES (semicolon-separated, pipe-delimited fields)
        # Format: agent|container_path|pane_name
        if [ -n "$mvb_panes" ]; then
            mvb_panes="${mvb_panes};"
        fi
        mvb_panes="${mvb_panes}${agent}|${container_path}|${pane_name}"

        echo -e "  Pane $i: ${GREEN}${agent}${NC} → ${host_path}"
    done

    start_host_watcher

    local claude_oauth_token
    claude_oauth_token=$(extract_oauth_token)

    # Launch container with dynamic volume mounts
    cd "$MVB_REPO"
    MVB_PROJECT="$session" \
    MVB_PANES="$mvb_panes" \
    MVB_SHARED="$shared" \
    MVB_WORKSPACE_VOLUME="mvb-default" \
    CLAUDE_CODE_OAUTH_TOKEN="$claude_oauth_token" \
    docker compose run --rm --service-ports \
        $volume_args \
        mvb
}

# Extract OAuth token from macOS Keychain
extract_oauth_token() {
    local token=""
    if command -v security &>/dev/null; then
        token=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null \
            | python3 -c "import sys,json; print(json.loads(sys.stdin.read())['claudeAiOauth']['accessToken'])" 2>/dev/null || true)
        if [ -n "$token" ]; then
            echo -e "Auth: ${GREEN}Pro subscription (OAuth from Keychain)${NC}" >&2
        fi
    fi
    echo "$token"
}

cmd_stop() {
    load_env
    echo -e "${YELLOW}Stopping multivibebox...${NC}"

    # Stop all mvb containers
    local containers
    containers=$(docker ps --format '{{.Names}}' | grep "^mvb-" || true)
    if [ -n "$containers" ]; then
        echo "$containers" | xargs docker stop
        echo -e "${GREEN}Containers stopped.${NC}"
    else
        echo "No running containers found."
    fi

    # Stop host watcher
    stop_host_watcher
    echo -e "${GREEN}Host watcher stopped.${NC}"

    # Clean up notify dir
    rm -f "$MVB_NOTIFY_DIR"/* 2>/dev/null || true
}

cmd_list() {
    mkdir -p "$MVB_PROJECTS_DIR"
    echo -e "${BLUE}Projects:${NC}"
    echo ""

    local found=false
    for pfile in "$MVB_PROJECTS_DIR"/*.json; do
        [ -f "$pfile" ] || continue
        found=true

        local name path shared agents last_used running
        name=$(jq -r '.name' "$pfile")
        path=$(jq -r '.path // "Docker volume"' "$pfile")
        shared=$(jq -r '.shared' "$pfile")
        agents=$(jq -r '.agents' "$pfile")
        last_used=$(jq -r '.last_used' "$pfile")

        if is_running "$name"; then
            running="${GREEN}● running${NC}"
        else
            running="${RED}○ stopped${NC}"
        fi

        echo -e "  $running  ${GREEN}$name${NC}"
        echo -e "           Agents: $agents"
        echo -e "           Path: ${path:-Docker volume}"
        echo -e "           Mode: $([ "$shared" = "true" ] && echo "shared" || echo "worktree")"
        echo -e "           Last used: $last_used"
        echo ""
    done

    if [ "$found" = "false" ]; then
        echo "  No projects yet. Run 'mvb start <name>' to create one."
    fi
}

cmd_attach() {
    local agent="${1:-}"
    local project=""

    # Find running container
    local container
    container=$(docker ps --format '{{.Names}}' | grep "^mvb-" | head -1)
    if [ -z "$container" ]; then
        echo -e "${RED}No running multivibebox container found.${NC}"
        exit 1
    fi

    if [ -z "$agent" ]; then
        # Attach to full tmux session
        docker exec -it "$container" tmux attach-session -t mvb
    else
        # Find the pane index for this agent and attach to it
        local pane_index
        pane_index=$(docker exec "$container" tmux list-panes -t mvb -F "#{pane_index}:#{pane_title}" 2>/dev/null \
            | grep ":${agent}$" | cut -d: -f1)

        if [ -z "$pane_index" ]; then
            echo -e "${RED}Agent '$agent' not found in running session.${NC}"
            echo "Available agents:"
            docker exec "$container" tmux list-panes -t mvb -F "  #{pane_title}" 2>/dev/null
            exit 1
        fi

        # Select the pane and attach
        docker exec -it "$container" bash -c "tmux select-pane -t mvb:main.${pane_index} && tmux attach-session -t mvb"
    fi
}

cmd_merge() {
    local container
    container=$(docker ps --format '{{.Names}}' | grep "^mvb-" | head -1)
    if [ -z "$container" ]; then
        echo -e "${RED}No running multivibebox container found.${NC}"
        exit 1
    fi

    echo -e "${BLUE}Agent branch status:${NC}"
    echo ""

    # Get list of agent branches
    local branches
    branches=$(docker exec "$container" git -C /workspace branch --list "agent/*" 2>/dev/null)
    if [ -z "$branches" ]; then
        echo "No agent branches found. Are you using worktree mode?"
        exit 0
    fi

    local base_branch
    base_branch=$(docker exec "$container" git -C /workspace rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")

    while IFS= read -r branch; do
        branch=$(echo "$branch" | xargs)
        [ -z "$branch" ] && continue

        local commits
        commits=$(docker exec "$container" git -C /workspace log --oneline "${base_branch}..${branch}" 2>/dev/null)

        if [ -z "$commits" ]; then
            echo -e "  ${YELLOW}$branch${NC} — no changes"
        else
            local count
            count=$(echo "$commits" | wc -l | xargs)
            echo -e "  ${GREEN}$branch${NC} — $count commit(s):"
            echo "$commits" | sed 's/^/    /'
        fi
        echo ""
    done <<< "$branches"

    # Interactive merge
    echo -e "${BLUE}Merge branches into $base_branch?${NC}"
    while IFS= read -r branch; do
        branch=$(echo "$branch" | xargs)
        [ -z "$branch" ] && continue

        local commits
        commits=$(docker exec "$container" git -C /workspace log --oneline "${base_branch}..${branch}" 2>/dev/null)
        [ -z "$commits" ] && continue

        echo ""
        echo -n "Merge $branch? [y/N] "
        read -r answer
        if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
            echo "Merging $branch..."
            docker exec "$container" git -C /workspace merge "$branch" --no-edit || {
                echo -e "${RED}Merge conflict! Resolve in the container, then continue.${NC}"
                echo "  Run: mvb attach"
                return 1
            }
            echo -e "${GREEN}Merged $branch successfully.${NC}"
        else
            echo "Skipped $branch."
        fi
    done <<< "$branches"
}

cmd_open() {
    local agent="${1:-}" file="${2:-}"

    # Find running container
    local container
    container=$(docker ps --format '{{.Names}}' | grep "^mvb-" | head -1)
    local project_name="${container#mvb-}"

    # Load project metadata
    local project_data
    project_data=$(load_project "$project_name")
    local workspace_path
    workspace_path=$(echo "$project_data" | jq -r '.path // empty')
    local shared
    shared=$(echo "$project_data" | jq -r '.shared // "false"')

    if [ -n "$workspace_path" ]; then
        # Bind-mount mode: translate container path to host path
        local host_path
        if [ -z "$agent" ] || [ "$shared" = "true" ]; then
            host_path="$workspace_path"
        else
            # Worktree is at .worktrees/agent-<name>/ on host side
            # (git worktree add creates them relative to the repo)
            host_path="$workspace_path"
            local worktree_path="$workspace_path/.git/worktrees"
            if [ -d "$worktree_path" ]; then
                # The actual worktree checkout is created by git inside the container
                # In bind-mount mode, it would be at the workspace root
                host_path="$workspace_path"
            fi
        fi

        if [ -n "$file" ]; then
            code "$host_path/$file"
        else
            code "$host_path"
        fi
    else
        # Volume mode: use VS Code remote container
        if [ -z "$container" ]; then
            echo -e "${RED}No running container found.${NC}"
            exit 1
        fi

        local container_id
        container_id=$(docker inspect --format='{{.Id}}' "$container")
        local folder="/workspace"
        [ -n "$agent" ] && [ "$shared" != "true" ] && folder="/workspace-${agent}"
        [ -n "$file" ] && folder="${folder}/${file}"

        local hex_container
        hex_container=$(printf '%s' "$container_id" | xxd -p | tr -d '\n')
        code --folder-uri "vscode-remote://attached-container+${hex_container}${folder}"
    fi
}

cmd_config() {
    local env_file="$MVB_REPO/config/.env"
    if [ ! -f "$env_file" ]; then
        cp "$MVB_REPO/config/.env.example" "$env_file"
        echo -e "${YELLOW}Created config/.env from template.${NC}"
    fi
    "${EDITOR:-vi}" "$env_file"
}

cmd_destroy() {
    local project="$1"
    if [ -z "$project" ]; then
        echo -e "${RED}Usage: mvb destroy <project>${NC}"
        exit 1
    fi

    echo -e "${YELLOW}This will remove project '$project' and its Docker volume.${NC}"
    echo -n "Are you sure? [y/N] "
    read -r answer
    if [ "$answer" != "y" ] && [ "$answer" != "Y" ]; then
        echo "Cancelled."
        exit 0
    fi

    # Stop if running
    if is_running "$project"; then
        docker stop "$(container_name "$project")" 2>/dev/null || true
    fi

    # Remove volume
    docker volume rm "mvb-${project}" 2>/dev/null || true

    # Remove project metadata
    rm -f "$(project_file "$project")"

    echo -e "${GREEN}Project '$project' destroyed.${NC}"
}

# ---- Main ----

case "${1:-help}" in
    start)   shift; cmd_start "$@" ;;
    stop)    cmd_stop ;;
    list)    cmd_list ;;
    attach)  shift; cmd_attach "$@" ;;
    merge)   cmd_merge ;;
    open)    shift; cmd_open "$@" ;;
    config)  cmd_config ;;
    destroy) shift; cmd_destroy "$@" ;;
    help|--help|-h) usage ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}" >&2
        usage
        exit 1
        ;;
esac
