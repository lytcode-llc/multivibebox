# Multivibebox Configuration
# Copy this file to .env and fill in your API keys.

# Required for Claude Code
ANTHROPIC_API_KEY=

# Optional: for agents that use OpenAI (Codex, etc.)
OPENAI_API_KEY=

# Comma-separated list of agents to start (must have matching .conf files)
MVB_AGENTS=claude

# Tmux layout: tiled, even-horizontal, even-vertical, main-horizontal, main-vertical
MVB_LAYOUT=tiled

# Maximum number of panes (agents). More than 6 gets hard to read.
MVB_MAX_PANES=6

# Notification cooldown in seconds (per agent)
MVB_NOTIFY_COOLDOWN=10
